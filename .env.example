# Example environment variables. Copy this file to .env for local runs.
API_PORT=8000
# API access key for protected endpoints. Set a real value in .env.
API_KEY=
# Optional default LLM provider for /analyze/llm-suggestions.
# Supported: openai, anthropic
LLM_PROVIDER=
# Optional default LLM model name for the selected provider.
LLM_MODEL=
# Optional API key for the selected LLM provider.
LLM_API_KEY=
# Optional custom base URL for OpenAI-compatible providers (e.g. Groq:
# https://api.groq.com/openai/v1). Leave empty to use OpenAI's default endpoint.
LLM_BASE_URL=
# Enable per-user session isolation. Set "true" to activate file-based user roots.
SESSION_USER_ISOLATION=false
# Root directory for per-user session files.
SESSION_USER_ROOT=/app/data/users
# Token TTL in seconds. Only used by /session/issue when expires_at is omitted or "auto".
SESSION_TOKEN_TTL=86400
